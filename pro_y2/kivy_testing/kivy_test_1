from kivy.app import App
from kivy.uix.floatlayout import FloatLayout
from kivy.factory import Factory
from kivy.properties import ObjectProperty
from kivy.uix.popup import Popup

import os
import matplotlib as plt
import pandas as pd


class LoadDialog(FloatLayout):
    load = ObjectProperty(None)
    cancel = ObjectProperty(None)

class ChartPopup(FloatLayout):
    chart_type = ObjectProperty(None)

class Root(FloatLayout):
    loadfile = ObjectProperty(None)
    saved_csv = ObjectProperty(None)

    def dismiss_popup(self):
        self._popup.dismiss()

    def show_load(self):
        content = LoadDialog(load=self.load, cancel=self.dismiss_popup)
        self._popup = Popup(title="Load file", content=content,
                            size_hint=(0.9, 0.9))
        self._popup.open()

    def load(self, path, filename):
        with open(os.path.join(path, filename[0])) as stream:
            self.saved_csv = stream.read()

        self.dismiss_popup()
    
    def popup_chart_window(self):
        content = ChartPopup(chart_type = None)
        self._popup = Popup(title="Choose", content=content)

        self._popup.open()

class Editor(App):
    pass


Factory.register('Root', cls=Root)
Factory.register('LoadDialog', cls=LoadDialog)
Factory.register('ChartPopup', cls=ChartPopup)


if __name__ == '__main__':
    Editor().run()
